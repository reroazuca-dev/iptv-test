function normalizeName(name){return(name||'').toLowerCase().replace(/[^a-z0-9]/g,' ').replace(/\s+/g,' ').trim();}

async function fetchWithProxy(url){
  const proxies=['https://api.allorigins.win/raw?url=','https://corsproxy.io/?url=','https://api.codetabs.com/v1/proxy?quest='];
  for(let i=0;i<proxies.length;i++){
    try{
      const r=await fetch(proxies[i]+encodeURIComponent(url),{signal:AbortSignal.timeout(8000)});
      if(r.ok){const t=await r.text();if(t.includes('#EXTM3U')||t.includes('#EXTINF'))return t;}
    }catch(e){continue;}
  }
  throw new Error('No se pudo descargar.');
}

async function loadIPTVStreams(){
  const urls=['https://iptv-org.github.io/iptv/languages/spa.m3u','https://iptv-org.github.io/iptv/categories/sports.m3u'];
  for(const url of urls){
    try{
      const text=await fetchWithProxy(url);
      const lines=text.split('\n').map(function(l){return l.trim();}).filter(Boolean);
      let meta={};
      for(let i=0;i<lines.length;i++){
        const line=lines[i];
        if(line.startsWith('#EXTINF')){
          const nm=line.match(/,(.+)$/);if(nm)meta.name=nm[1].trim();
        }else if(!line.startsWith('#')&&meta.name){
          iptvStreams[normalizeName(meta.name)]=line;meta={};
        }
      }
    }catch(e){console.warn('No se pudo cargar:',url);}
  }
  console.log('📡 Streams IPTV cargados:',Object.keys(iptvStreams).length);
}

function findStream(channelName){
  const norm=normalizeName(channelName);
  if(iptvStreams[norm])return iptvStreams[norm];
  for(const key of Object.keys(iptvStreams)){
    if(key.includes(norm)||norm.includes(key))return iptvStreams[key];
  }
  return null;
