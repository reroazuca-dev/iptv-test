async function doLogin(){
  if(!sb){toast('Usa acceso sin cuenta','err');return;}
  var email=$('loginEmail').value.trim(),pass=$('loginPass').value;
  if(!email||!pass){showMsg('authMsg','Completa todos los campos');return;}
  var btn=$('btnLogin');btn.disabled=true;btn.textContent='Cargando...';
  try{
    var r=await sb.auth.signInWithPassword({email:email,password:pass});
    btn.disabled=false;btn.innerHTML='▶ ENTRAR';
    if(r.error){showMsg('authMsg',r.error.message==='Invalid login credentials'?'Correo o contraseña incorrectos':r.error.message);return;}
    hideMsg('authMsg');currentUser=r.data.user;safeSet('navName','textContent',r.data.user.email.split('@')[0]);enterApp();
  }catch(e){btn.disabled=false;btn.innerHTML='▶ ENTRAR';showMsg('authMsg','Error de conexión');}
}
async function doRegister(){
  if(!sb){toast('Supabase no configurado','err');return;}
  var email=$('regEmail').value.trim(),pass=$('regPass').value,pass2=$('regPass2').value;
  if(!email||!pass||!pass2){showMsg('authMsg','Completa todos los campos');return;}
  if(pass!==pass2){showMsg('authMsg','Las contraseñas no coinciden');return;}
  if(pass.length<6){showMsg('authMsg','Mínimo 6 caracteres');return;}
  var btn=$('btnRegister');btn.disabled=true;btn.textContent='Creando...';
  try{
    var r=await sb.auth.signUp({email:email,password:pass});
    btn.disabled=false;btn.innerHTML='✦ CREAR CUENTA';
    if(r.error){showMsg('authMsg',r.error.message);return;}
    showMsg('authMsg','✅ Cuenta creada. Revisa tu correo.','success');
  }catch(e){btn.disabled=false;btn.innerHTML='✦ CREAR CUENTA';showMsg('authMsg','Error de conexión');}
}
async function doForgot(){
  if(!sb){toast('Supabase no configurado','err');return;}
  var email=$('forgotEmail').value.trim();
  if(!email){showMsg('authMsg','Ingresa tu correo');return;}
  try{
    var r=await sb.auth.resetPasswordForEmail(email,{redirectTo:window.location.href});
    if(r.error){showMsg('authMsg',r.error.message);return;}
    showMsg('authMsg','✅ Enlace enviado. Revisa tu correo.','success');
  }catch(e){showMsg('authMsg','Error de conexión');}
}
async function doLogout(){
  if(sb&&currentUser)try{await sb.auth.signOut();}catch(e){}
