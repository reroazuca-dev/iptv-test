async function importM3U(url,name){
  toast('Cargando '+name+'...','inf');
  try{
    var text=await fetchWithProxy(url);
    var channels=parseM3U(text);
    if(!channels.length){toast('Sin canales encontrados','err');return;}
    loadedM3U=channels;renderLoadedM3U(name,channels);
    toast('✅ '+channels.length+' canales de '+name,'ok');
    showPage('m3u');
    setTimeout(function(){var el=$('m3uLoaded');if(el)el.scrollIntoView({behavior:'smooth'});},300);
  }catch(e){toast('Error: '+e.message,'err');}
}
async function importM3UCustom(){
  var url=$('customM3uUrl').value.trim();if(!url){toast('Ingresa una URL','err');return;}
  await importM3U(url,'Lista personalizada');
}
function pasteM3U(){
  var text=prompt('Pega el contenido M3U:');if(!text)return;
  var channels=parseM3U(text);if(!channels.length){toast('Sin canales','err');return;}
  loadedM3U=channels;renderLoadedM3U('Pegado',channels);toast('✅ '+channels.length+' canales importados','ok');
}
function parseM3U(text){
  var lines=text.split('\n').map(function(l){return l.trim();}).filter(Boolean);
  var chs=[],meta={};
  for(var i=0;i<lines.length;i++){
    var line=lines[i];
    if(line.startsWith('#EXTINF')){
      meta={name:'Canal',logo:'',group:'General',icon:'📺',progress:Math.floor(Math.random()*80)+10};
      var nm=line.match(/,(.+)$/);if(nm)meta.name=nm[1].trim();
      var lo=line.match(/tvg-logo="([^"]+)"/);if(lo)meta.logo=lo[1];
      var gr=line.match(/group-title="([^"]+)"/);if(gr)meta.group=gr[1];
    }else if(!line.startsWith('#')&&meta.name){
      chs.push(Object.assign({},meta,{url:line,hasDirectStream:true,streamUrl:line}));meta={};
    }
  }
  return chs;
}
function renderLoadedM3U(name,chs){
  var groups=[...new Set(chs.map(function(c){return c.group;}))];
  safeSet('m3uLoadedTitle','textContent','✅ '+chs.length+' canales — '+name);
  var el=$('m3uLoaded');if(el)el.style.display='block';
  var gt=$('m3uGroupTabs');if(!gt)return;
  gt.innerHTML='<button class="tab active" data-grp="">Todos ('+chs.length+')</button>'
    +groups.slice(0,15).map(function(g){return '<button class="tab" data-grp="'+g+'">'+g+' ('+chs.filter(function(c){return c.group===g;}).length+')</button>';}).join('');
  gt.querySelectorAll('.tab').forEach(function(btn){
    btn.addEventListener('click',function(){gt.querySelectorAll('.tab').forEach(function(t){t.classList.remove('active');});btn.classList.add('active');filterGroup(chs,btn.dataset.grp);});
  });
  filterGroup(chs,'');
}
function filterGroup(chs,group){
  var list=group?chs.filter(function(c){return c.group===group;}):chs;
  var showing=Math.min(120,list.length);
  function renderCards(items){
    return items.map(function(c){
      var logo=c.logo?'<img src="'+c.logo+'" style="width:100%;height:100%;object-fit:cover;border-radius:6px" onerror="this.parentElement.textContent=\'📺\'">':c.icon;
      return '<div class="ch-card" data-ch="'+encodeURIComponent(JSON.stringify(c))+'"><div class="ch-top"><div class="ch-icon">'+logo+'</div><div class="live-pill"><div class="ldot"></div>EN VIVO</div></div><div class="ch-name">'+c.name+'</div><div class="ch-prog">📺 '+c.group+'</div><div class="ch-prog-bar"><div class="ch-prog-fill" style="width:'+c.progress+'%"></div></div></div>';
    }).join('');
  }
  var grid=$('m3uChannelGrid');if(!grid)return;
  grid.innerHTML=renderCards(list.slice(0,showing));
  if(list.length>showing){
    var more=document.createElement('div');more.style.cssText='grid-column:1/-1;text-align:center;padding:1rem;';
    more.innerHTML='<button class="btn btn-ghost" id="btnLoadMore">⬇ Ver '+(list.length-showing)+' canales más</button>';
    grid.appendChild(more);
    $('btnLoadMore').addEventListener('click',function(){grid.innerHTML=renderCards(list);bindChannels(grid);});
  }
  bindChannels(grid);
}
function clearM3U(){loadedM3U=[];var el=$('m3uLoaded');if(el)el.style.display='none';}

function destroyPlayer(){
  if(currentPlayer){try{if(currentPlayer._hls)currentPlayer._hls.destroy();currentPlayer.pause();currentPlayer.src='';}catch(e){}currentPlayer=null;}
  var pc=$('playerContainer');if(pc)pc.innerHTML='<div class="no-vid-ph"><div class="ic">▶</div><p>// PRESIONA REPRODUCIR PARA VER</p></div>';
}
function initPlayer(src,fallbackEmbed){
  var pc=$('playerContainer');if(!pc)return;
  if(!src&&fallbackEmbed){loadEmbed(fallbackEmbed);return;}
  if(!src){toast('Sin URL de reproducción','err');return;}
  pc.innerHTML='<video id="mainVideo" controls autoplay playsinline style="width:100%;height:100%;min-height:300px;background:#000;display:block;"></video>';
  var video=$('mainVideo');currentPlayer=video;
  var isHLS=src.includes('.m3u8')||src.includes('/hls/')||src.toLowerCase().includes('m3u8');
  if(isHLS&&typeof Hls!=='undefined'&&Hls.isSupported()){
    var hls=new Hls({enableWorker:true,lowLatencyMode:true,backBufferLength:90});
    hls.loadSource(src);hls.attachMedia(video);
    hls.on(Hls.Events.MANIFEST_PARSED,function(){video.play().catch(function(){});});
    hls.on(Hls.Events.ERROR,function(e,data){
      if(data.fatal){
        if(data.type===Hls.ErrorTypes.NETWORK_ERROR)hls.startLoad();
        else if(data.type===Hls.ErrorTypes.MEDIA_ERROR)hls.recoverMediaError();
        else{hls.destroy();if(fallbackEmbed)setTimeout(function(){loadEmbed(fallbackEmbed);},500);}
      }
    });
    if(fallbackEmbed)setTimeout(function(){if(video.readyState===0){hls.destroy();loadEmbed(fallbackEmbed);}},10000);
    video._hls=hls;
  }else if(video.canPlayType('application/vnd.apple.mpegurl')&&isHLS){
    video.src=src;video.addEventListener('loadedmetadata',function(){video.play().catch(function(){});});
    video.addEventListener('error',function(){if(fallbackEmbed)loadEmbed(fallbackEmbed);});
  }else{
    video.src=src;video.play().catch(function(){});
    video.addEventListener('error',function(){if(fallbackEmbed)loadEmbed(fallbackEmbed);});
  }
}
function loadEmbed(url){
  currentPlayer=null;var pc=$('playerContainer');if(!pc)return;
  pc.innerHTML='<iframe src="'+url+'" style="width:100%;height:100%;min-height:300px;border:none;background:#000;display:block;" allow="autoplay; encrypted-media; fullscreen *; picture-in-picture" referrerpolicy="no-referrer"></iframe>';
}

function getActiveSourceIdx(){var btns=$('sourceButtons');if(!btns)return 0;var active=btns.querySelector('.source-btn.active');return active?parseInt(active.dataset.idx)||0:0;}
function loadEmbedWithSourceSelector(type,tmdbId,season,episode){
  currentModalType=type;currentModalId=tmdbId;currentSeason=season||1;currentEpisode=episode||1;
  var switcher=$('sourceSwitcher'),btns=$('sourceButtons');if(!switcher||!btns)return;
  switcher.style.display='block';
  btns.innerHTML=SOURCE_NAMES.map(function(name,i){return '<button class="source-btn'+(i===0?' active':'')+'" data-idx="'+i+'">'+name+'</button>';}).join('');
  btns.querySelectorAll('.source-btn').forEach(function(btn){
    btn.addEventListener('click',function(){btns.querySelectorAll('.source-btn').forEach(function(b){b.classList.remove('active');});btn.classList.add('active');playFromSource(parseInt(btn.dataset.idx));});
  });
  var subBar=$('subtitleBar');if(subBar)subBar.style.display='flex';
  playFromSource(0);
}
function playFromSource(idx){
  var sources=currentModalType==='movie'?EMBED_SOURCES_MOVIE:EMBED_SOURCES_TV;
  if(idx>=sources.length){toast('Sin más fuentes','err');return;}
  var lang=currentSubLang||'es';var url;
  try{url=currentModalType==='movie'?sources[idx](currentModalId,lang):sources[idx](currentModalId,currentSeason,currentEpisode,lang);}
  catch(e){toast('Error generando URL','err');return;}
  loadEmbed(url);
}

async function loadSeasons(tmdbId){
  try{
    var d=await tmdb('/tv/'+tmdbId,'');if(!d||!d.seasons)return;
    var seasons=d.seasons.filter(function(s){return s.season_number>0;});if(!seasons.length)return;
    var sel=$('selSeason');if(!sel)return;
    sel.innerHTML=seasons.map(function(s){return '<option value="'+s.season_number+'">Temporada '+s.season_number+' ('+s.episode_count+' ep.)</option>';}).join('');
    await loadEpisodes(tmdbId,seasons[0].season_number);
    sel.onchange=function(){loadEpisodes(tmdbId,parseInt(sel.value));};
  }catch(e){}
}
async function loadEpisodes(tmdbId,seasonNum){
  try{
    var d=await tmdb('/tv/'+tmdbId+'/season/'+seasonNum,'');if(!d||!d.episodes)return;
    var sel=$('selEpisode');if(!sel)return;
    sel.innerHTML=d.episodes.map(function(e){return '<option value="'+e.episode_number+'">Ep. '+e.episode_number+' — '+(e.name||'Episodio '+e.episode_number)+'</option>';}).join('');
  }catch(e){}
}

function showPage(id){
  document.querySelectorAll('.page').forEach(function(p){p.classList.remove('active');});
