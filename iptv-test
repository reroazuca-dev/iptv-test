var searchTimer=null;
function initSearch(){
  var inp=$('searchInput'),res=$('searchResults');if(!inp||!res)return;
  inp.addEventListener('input',function(){
    clearTimeout(searchTimer);var q=inp.value.trim();
    if(q.length<2){res.style.display='none';return;}
    searchTimer=setTimeout(function(){doSearch(q);},400);
  });
  inp.addEventListener('keydown',function(e){if(e.key==='Escape'){res.style.display='none';inp.value='';}});
  document.addEventListener('click',function(e){if(!inp.contains(e.target)&&!res.contains(e.target))res.style.display='none';});
}
async function doSearch(q){
  var res=$('searchResults');res.style.display='block';
  res.innerHTML='<div style="padding:1rem;text-align:center;"><div class="spinner" style="margin:0 auto;"></div></div>';
  var results=await Promise.all([tmdb('/search/movie','&query='+encodeURIComponent(q)),tmdb('/search/tv','&query='+encodeURIComponent(q))]);
  var movies=results[0]&&results[0].results?results[0].results.slice(0,5):[];
  var series=results[1]&&results[1].results?results[1].results.slice(0,5):[];
  if(!movies.length&&!series.length){res.innerHTML='<div style="padding:1.25rem;color:var(--muted2);font-family:Share Tech Mono,monospace;font-size:.8rem;text-align:center;">Sin resultados para "'+q+'"</div>';return;}
  var html='';
  if(movies.length){
    html+='<div style="padding:.5rem 1rem .25rem;font-size:.65rem;color:var(--red);font-family:Share Tech Mono,monospace;letter-spacing:1px;border-bottom:1px solid rgba(255,255,255,.05);">🎬 PELÍCULAS</div>';
    html+=movies.map(function(m){
      var data=encodeURIComponent(JSON.stringify({id:m.id,title:m.title,overview:m.overview,vote_average:m.vote_average,release_date:m.release_date,type:'movie'}));
      var img=m.poster_path?'<img src="https://image.tmdb.org/t/p/w92'+m.poster_path+'" style="width:36px;height:54px;object-fit:cover;border-radius:3px;flex-shrink:0;" onerror="this.style.display=\'none\'">':'<div style="width:36px;height:54px;background:#222;border-radius:3px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">🎬</div>';
      return '<div class="search-item" data-item="'+data+'" style="display:flex;align-items:center;gap:.75rem;padding:.6rem 1rem;cursor:pointer;border-bottom:1px solid rgba(255,255,255,.03);">'+img+'<div><div style="font-size:.88rem;font-weight:700;">'+(m.title||'—')+'</div><div style="font-size:.7rem;color:var(--muted2);">'+(m.release_date||'').slice(0,4)+' · ★'+(m.vote_average||0).toFixed(1)+'</div></div></div>';
    }).join('');
  }
  if(series.length){
    html+='<div style="padding:.5rem 1rem .25rem;font-size:.65rem;color:var(--cyan);font-family:Share Tech Mono,monospace;letter-spacing:1px;border-bottom:1px solid rgba(255,255,255,.05);">📺 SERIES / TV</div>';
    html+=series.map(function(s){
      var data=encodeURIComponent(JSON.stringify({id:s.id,name:s.name,title:s.name,overview:s.overview,vote_average:s.vote_average,first_air_date:s.first_air_date,type:'tv'}));
      var img=s.poster_path?'<img src="https://image.tmdb.org/t/p/w92'+s.poster_path+'" style="width:36px;height:54px;object-fit:cover;border-radius:3px;flex-shrink:0;" onerror="this.style.display=\'none\'">':'<div style="width:36px;height:54px;background:#222;border-radius:3px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">📺</div>';
      return '<div class="search-item" data-item="'+data+'" style="display:flex;align-items:center;gap:.75rem;padding:.6rem 1rem;cursor:pointer;border-bottom:1px solid rgba(255,255,255,.03);">'+img+'<div><div style="font-size:.88rem;font-weight:700;">'+(s.name||'—')+'</div><div style="font-size:.7rem;color:var(--muted2);">'+(s.first_air_date||'').slice(0,4)+' · ★'+(s.vote_average||0).toFixed(1)+'</div></div></div>';
    }).join('');
  }
  res.innerHTML=html;
  res.querySelectorAll('.search-item').forEach(function(item){
    item.addEventListener('mouseover',function(){this.style.background='rgba(255,255,255,.05)';});
    item.addEventListener('mouseout',function(){this.style.background='';});
    item.addEventListener('click',function(){res.style.display='none';$('searchInput').value='';try{openModal(JSON.parse(decodeURIComponent(item.dataset.item)));}catch(e){}});
  });
}

