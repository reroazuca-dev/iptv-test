function openModal(m){
  if(!m)return;
  var isSeries=m.type==='tv'||!!m.first_air_date||(!!m.name&&!m.title);
  var mTitle=$('mTitle'),mDesc=$('mDesc'),mMeta=$('mMeta');
  if(mTitle)mTitle.textContent=m.title||m.name||'—';
  if(mDesc)mDesc.textContent=m.overview||'Sin descripción disponible.';
  if(mMeta)mMeta.innerHTML='<span style="color:var(--gold)">★'+(m.vote_average||0).toFixed(1)+'</span>'
    +'<span>'+(m.release_date||m.first_air_date||'').slice(0,4)+'</span>'
    +'<span>'+(isSeries?'Serie / TV':'Película')+'</span>'
    +'<span style="background:rgba(229,9,20,.1);border:1px solid rgba(229,9,20,.3);border-radius:3px;padding:1px 5px;font-size:.65rem;color:var(--red)">TMDB #'+m.id+'</span>';
  destroyPlayer();
  var ss=$('sourceSwitcher'),sb2=$('subtitleBar');if(ss)ss.style.display='none';if(sb2)sb2.style.display='none';
  var modal=$('modal');if(modal)modal.classList.add('open');
  if(isSeries&&m.id){
    var ep=$('episodeSelector'),bp=$('btnModalPlay');
    if(ep)ep.style.display='block';if(bp)bp.style.display='none';
    loadSeasons(m.id);
    var bpe=$('btnPlayEpisode');
    if(bpe)bpe.onclick=function(){
      var s=parseInt($('selSeason').value)||1,e=parseInt($('selEpisode').value)||1;
      loadEmbedWithSourceSelector('tv',m.id,s,e);
    };
  }else{
    var ep=$('episodeSelector'),bp=$('btnModalPlay');
    if(ep)ep.style.display='none';
    if(bp){bp.style.display='inline-flex';bp.innerHTML='▶ REPRODUCIR';
      bp.onclick=function(){
        if(m.url)initPlayer(m.url,m.id?EMBED_SOURCES_MOVIE[0](m.id,currentSubLang):null);
        else if(m.id)loadEmbedWithSourceSelector('movie',m.id);
        else toast('Sin fuente de reproducción','err');
      };
    }
  }
}

function openChannelModal(c){
  if(!c)return;
  var mTitle=$('mTitle'),mDesc=$('mDesc'),mMeta=$('mMeta');
  if(mTitle)mTitle.textContent=c.name;
  if(mDesc)mDesc.textContent='Transmisión en vivo — '+(c.prog||c.group||'Canal');
  if(mMeta)mMeta.innerHTML='<span style="color:var(--red)">● EN VIVO</span>'
    +'<span>'+(c.group||'General')+'</span>'
    +(c.hasDirectStream
      ?'<span style="background:rgba(0,230,118,.1);border:1px solid rgba(0,230,118,.3);border-radius:3px;padding:1px 6px;font-size:.65rem;color:var(--green)">▶ STREAM DIRECTO</span>'
      :'<span style="background:rgba(255,165,0,.1);border:1px solid rgba(255,165,0,.3);border-radius:3px;padding:1px 6px;font-size:.65rem;color:orange">📺 EXTERNO</span>');
  var ep=$('episodeSelector'),ss=$('sourceSwitcher'),sb2=$('subtitleBar'),bp=$('btnModalPlay');
  if(ep)ep.style.display='none';if(sb2)sb2.style.display='none';
  destroyPlayer();
  var modal=$('modal');if(modal)modal.classList.add('open');

  if(c.hasDirectStream&&c.streamUrl){
    if(ss)ss.style.display='none';
    if(bp){bp.style.display='inline-flex';bp.innerHTML='▶ REPRODUCIR';bp.onclick=function(){initPlayer(c.streamUrl,null);};}
    setTimeout(function(){initPlayer(c.streamUrl,null);},300);
  }else if(c.players&&c.players.length>0){
    if(ss)ss.style.display='none';
    var pc=$('playerContainer');
    if(pc)pc.innerHTML='<div class="no-vid-ph"><div class="ic">📺</div><p style="color:var(--muted2);font-size:.85rem;text-align:center;padding:0 2rem;">Este canal no tiene stream directo.<br>Haz clic en el botón para verlo en el sitio original.</p></div>';
    if(bp){bp.style.display='inline-flex';bp.innerHTML='📺 Ver canal externo';
      bp.onclick=function(){window.open(c.players[0],'_blank');};}
  }else if(c.url){
    if(ss)ss.style.display='none';
    if(bp){bp.style.display='inline-flex';bp.innerHTML='▶ REPRODUCIR';bp.onclick=function(){initPlayer(c.url,null);};}
    setTimeout(function(){initPlayer(c.url,null);},300);
  }else{
    if(ss)ss.style.display='none';
    if(bp){bp.style.display='inline-flex';bp.onclick=function(){toast('Sin URL de reproducción','err');};}
  }
}

function closeModal(){
  destroyPlayer();
