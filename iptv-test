  return '<div class="m3u-card" style="animation-delay:'+(i*.04)+'s" data-url="'+l.url+'" data-name="'+l.name+'"><div class="m3u-card-top"><div class="m3u-flag">'+l.flag+'</div><div><div class="m3u-card-title">'+l.name+'</div><div class="m3u-card-count">'+l.count+' canales</div></div></div><div class="m3u-card-desc">'+l.desc+'</div><div class="m3u-btns"><button class="btn btn-red btn-sm btn-load-m3u">⬇ Cargar</button><button class="btn btn-ghost btn-sm btn-copy-m3u">📋 URL</button></div></div>';
}
function bindM3UCards(container){
  container.querySelectorAll('.m3u-card').forEach(function(card){
    card.querySelector('.btn-load-m3u').addEventListener('click',function(e){e.stopPropagation();importM3U(card.dataset.url,card.dataset.name);});
    card.querySelector('.btn-copy-m3u').addEventListener('click',function(e){e.stopPropagation();navigator.clipboard&&navigator.clipboard.writeText(card.dataset.url).then(function(){toast('URL copiada','ok');});});
  });
}
function renderM3UGrid(){
