<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EdgarAI Stream</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@300;400;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
<style>
:root{
  --bg:#080808;--bg2:#0f0f0f;--card:#141414;--border:rgba(255,255,255,.08);
  --red:#e50914;--red2:#b20710;--cyan:#00f5ff;--pink:#ff2d78;--gold:#ffd700;
  --white:#ffffff;--muted:#555;--muted2:#888;--green:#00e676;--r:6px;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--white);font-family:'Barlow Condensed',sans-serif;min-height:100vh;overflow-x:hidden;}
::-webkit-scrollbar{width:4px;}::-webkit-scrollbar-track{background:var(--bg);}::-webkit-scrollbar-thumb{background:var(--red);border-radius:2px;}
.btn{display:inline-flex;align-items:center;gap:.45rem;padding:.65rem 1.5rem;border-radius:4px;font-family:'Barlow Condensed',sans-serif;font-size:.95rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer;border:none;transition:all .2s;white-space:nowrap;}
.btn-red{background:var(--red);color:#fff;box-shadow:0 0 20px rgba(229,9,20,.3);}
.btn-red:hover{background:var(--red2);transform:translateY(-1px);}
.btn-cyan{background:var(--cyan);color:#080808;}
.btn-cyan:hover{transform:translateY(-1px);box-shadow:0 0 30px rgba(0,245,255,.4);}
.btn-ghost{background:rgba(255,255,255,.1);color:var(--white);border:1px solid rgba(255,255,255,.2);}
.btn-ghost:hover{background:rgba(255,255,255,.2);}
.btn-full{width:100%;justify-content:center;}
.btn-sm{padding:.35rem .8rem;font-size:.78rem;}
.btn:disabled{opacity:.4;cursor:not-allowed;transform:none!important;}
.field{display:flex;flex-direction:column;gap:.4rem;margin-bottom:1rem;}
.field label{font-size:.7rem;font-weight:700;color:var(--muted2);letter-spacing:1.5px;text-transform:uppercase;font-family:'Share Tech Mono',monospace;}
.field input{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);border-radius:4px;padding:.7rem 1rem;color:var(--white);font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;transition:all .2s;}
.field input:focus{border-color:var(--red);box-shadow:0 0 10px rgba(229,9,20,.15);}
.field input::placeholder{color:var(--muted);}
.screen{display:none;min-height:100vh;}.screen.active{display:flex;}
#authScreen{align-items:stretch;background:var(--bg);}
.auth-left{flex:1;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;min-height:100vh;}
.auth-left-bg{position:absolute;inset:0;background-size:cover;background-position:center;filter:brightness(.35) saturate(1.2);}
.auth-left-overlay{position:absolute;inset:0;background:linear-gradient(to right,transparent 40%,var(--bg) 100%),linear-gradient(to top,var(--bg) 0%,transparent 25%);}
.auth-mascot{position:relative;z-index:2;display:flex;flex-direction:column;align-items:center;gap:1.5rem;padding:3rem 2rem;}
.auth-mascot-img{width:260px;height:320px;border-radius:16px;overflow:hidden;border:2px solid rgba(229,9,20,.4);box-shadow:0 0 60px rgba(229,9,20,.2);position:relative;animation:floatMascot 5s ease-in-out infinite;background:#111;display:flex;align-items:center;justify-content:center;font-size:5rem;}
.auth-mascot-img img{width:100%;height:100%;object-fit:cover;object-position:center top;display:block;}
.auth-mascot-img::after{content:'';position:absolute;left:0;right:0;height:2px;top:0;background:linear-gradient(90deg,transparent,rgba(229,9,20,.9),transparent);animation:scanLine 2.5s linear infinite;}
@keyframes scanLine{0%{top:-2px;opacity:0}10%{opacity:1}90%{opacity:.3}100%{top:100%;opacity:0}}
@keyframes floatMascot{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
.auth-mascot-name{font-family:'Bebas Neue',cursive;font-size:2.2rem;letter-spacing:4px;background:linear-gradient(90deg,#fff,var(--red),var(--cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;text-align:center;}
.auth-right{width:420px;min-width:360px;display:flex;align-items:center;justify-content:center;padding:2rem;background:rgba(8,8,8,.97);border-left:1px solid rgba(255,255,255,.05);}
.auth-box{width:100%;max-width:360px;}
.auth-brand-sm{display:flex;align-items:center;gap:.75rem;margin-bottom:2rem;}
.auth-brand-img{width:38px;height:38px;border-radius:8px;overflow:hidden;border:1.5px solid rgba(229,9,20,.5);background:#111;display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0;}
.auth-brand-img img{width:100%;height:100%;object-fit:cover;}
.auth-brand-text{font-family:'Bebas Neue',cursive;font-size:1.5rem;letter-spacing:2px;background:linear-gradient(90deg,#fff,var(--red));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.auth-tabs{display:flex;border-radius:4px;overflow:hidden;border:1px solid rgba(255,255,255,.08);margin-bottom:1.75rem;}
.auth-tab{flex:1;padding:.6rem;text-align:center;font-size:.9rem;font-weight:700;letter-spacing:1px;cursor:pointer;transition:all .2s;color:var(--muted2);background:transparent;border:none;font-family:'Barlow Condensed',sans-serif;}
.auth-tab.active{background:var(--red);color:#fff;}
.auth-form{display:none;}.auth-form.active{display:block;}
.auth-divider{text-align:center;margin:1rem 0;position:relative;}
.auth-divider::before{content:'';position:absolute;top:50%;left:0;right:0;height:1px;background:rgba(255,255,255,.08);}
.auth-divider span{position:relative;background:rgba(8,8,8,.97);padding:0 .75rem;font-size:.7rem;color:var(--muted);font-family:'Share Tech Mono',monospace;}
.msg{padding:.6rem 1rem;border-radius:4px;font-size:.8rem;margin-bottom:1rem;display:none;font-family:'Share Tech Mono',monospace;line-height:1.5;}
.msg.error{background:rgba(229,9,20,.1);border:1px solid rgba(229,9,20,.3);color:#ff6b6b;}
.msg.success{background:rgba(0,230,118,.1);border:1px solid rgba(0,230,118,.3);color:var(--green);}
.msg.show{display:block;}
#appScreen{flex-direction:column;}
.navbar{position:sticky;top:0;z-index:200;height:60px;display:flex;align-items:center;justify-content:space-between;padding:0 2.5rem;background:linear-gradient(to bottom,rgba(8,8,8,.98),rgba(8,8,8,.85));border-bottom:1px solid rgba(255,255,255,.05);backdrop-filter:blur(16px);}
.brand{display:flex;align-items:center;gap:.7rem;cursor:pointer;}
.brand-img{width:32px;height:32px;border-radius:6px;overflow:hidden;border:1.5px solid rgba(229,9,20,.5);background:#111;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;}
.brand-img img{width:100%;height:100%;object-fit:cover;display:block;}
.brand-text{font-family:'Bebas Neue',cursive;font-size:1.5rem;letter-spacing:3px;background:linear-gradient(90deg,#fff,var(--red));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.nav-links{display:flex;gap:1.5rem;list-style:none;}
.nav-links a{color:rgba(255,255,255,.65);font-size:.88rem;font-weight:600;text-decoration:none;letter-spacing:.8px;text-transform:uppercase;transition:color .2s;cursor:pointer;}
.nav-links a:hover{color:var(--white);}
.nav-links a.active{color:var(--white);}
.nav-right{display:flex;align-items:center;gap:.85rem;}
.nav-search{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:4px;padding:.38rem .8rem;color:var(--white);font-family:'Barlow Condensed',sans-serif;font-size:.88rem;outline:none;width:160px;transition:all .3s;}
.nav-search:focus{border-color:var(--red);width:220px;}
.nav-search::placeholder{color:var(--muted);}
.user-menu{position:relative;}
.user-btn{display:flex;align-items:center;gap:.45rem;cursor:pointer;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);border-radius:6px;padding:.28rem .6rem .28rem .28rem;transition:all .2s;}
.user-btn:hover{border-color:rgba(229,9,20,.4);}
.user-av{width:28px;height:28px;border-radius:5px;overflow:hidden;border:1px solid rgba(229,9,20,.4);background:#111;display:flex;align-items:center;justify-content:center;font-size:.9rem;flex-shrink:0;}
.user-av img{width:100%;height:100%;object-fit:cover;object-position:center top;display:block;}
.user-name{font-size:.82rem;font-weight:700;letter-spacing:.4px;max-width:80px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.user-dropdown{position:absolute;top:calc(100% + 8px);right:0;background:var(--bg2);border:1px solid rgba(255,255,255,.1);border-radius:8px;min-width:175px;box-shadow:0 20px 50px rgba(0,0,0,.7);overflow:hidden;display:none;z-index:300;}
.user-dropdown.open{display:block;}
.dd-item{display:flex;align-items:center;gap:.6rem;padding:.75rem 1rem;font-size:.85rem;font-weight:600;cursor:pointer;transition:background .2s;border-bottom:1px solid rgba(255,255,255,.05);}
.dd-item:last-child{border-bottom:none;}
.dd-item:hover{background:rgba(255,255,255,.06);}
.dd-item.danger:hover{background:rgba(229,9,20,.08);color:#ff6b6b;}
.page{display:none;}.page.active{display:block;}
.hero{position:relative;height:85vh;min-height:560px;display:flex;align-items:flex-end;padding:0 2.5rem 4rem;overflow:hidden;}
.hero-bg-img{position:absolute;inset:0;background-size:cover;background-position:center;filter:brightness(.3);}
.hero-ov1{position:absolute;inset:0;background:linear-gradient(to top,var(--bg) 0%,rgba(8,8,8,.6) 40%,transparent 70%);}
.hero-ov2{position:absolute;inset:0;background:linear-gradient(to right,rgba(8,8,8,.95) 30%,transparent 65%);}
.hero-char{position:absolute;right:4%;bottom:0;width:320px;display:flex;align-items:flex-end;z-index:2;}
.hero-char-img{width:100%;position:relative;mask-image:linear-gradient(to top,rgba(0,0,0,1) 0%,rgba(0,0,0,1) 75%,transparent 100%);-webkit-mask-image:linear-gradient(to top,rgba(0,0,0,1) 0%,rgba(0,0,0,1) 75%,transparent 100%);}
.hero-char-img img{width:100%;display:block;animation:heroFloat 5s ease-in-out infinite;}
@keyframes heroFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
.hero-content{position:relative;z-index:3;max-width:520px;}
.hero-eyebrow{font-family:'Share Tech Mono',monospace;font-size:.68rem;letter-spacing:3px;color:var(--red);margin-bottom:.75rem;display:flex;align-items:center;gap:.5rem;}
.hero-eyebrow::before{content:'';width:18px;height:1px;background:var(--red);}
.hero-title{font-family:'Bebas Neue',cursive;font-size:clamp(3rem,6.5vw,5rem);line-height:.9;letter-spacing:2px;margin-bottom:.85rem;}
.hero-title .t1{display:block;color:#fff;}
.hero-title .t2{display:block;color:var(--red);font-size:85%;}
.hero-meta{display:flex;gap:.75rem;align-items:center;margin-bottom:.85rem;font-size:.82rem;flex-wrap:wrap;color:rgba(255,255,255,.7);}
.hero-meta .r{color:var(--gold);font-weight:700;}
.hero-meta .tag{background:rgba(229,9,20,.15);border:1px solid rgba(229,9,20,.3);border-radius:3px;padding:1px 6px;font-size:.68rem;color:var(--red);font-family:'Share Tech Mono',monospace;}
.hero-desc{font-size:.92rem;color:rgba(255,255,255,.6);line-height:1.7;max-width:420px;margin-bottom:1.5rem;}
.hero-btns{display:flex;gap:.75rem;flex-wrap:wrap;}
.section{padding:1.75rem 2.5rem;}
.sec-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:1.1rem;}
.sec-title{font-family:'Bebas Neue',cursive;font-size:1.35rem;letter-spacing:2px;display:flex;align-items:center;gap:.5rem;}
.sec-title::before{content:'';width:3px;height:20px;border-radius:2px;background:var(--red);flex-shrink:0;}
.sec-link{font-size:.7rem;color:var(--red);cursor:pointer;font-family:'Share Tech Mono',monospace;letter-spacing:1px;opacity:.8;transition:opacity .2s;}
.sec-link:hover{opacity:1;}
.tabs{display:flex;gap:.35rem;margin-bottom:1.25rem;flex-wrap:wrap;}
.tab{padding:.38rem .88rem;border-radius:3px;font-size:.8rem;font-weight:700;letter-spacing:.8px;cursor:pointer;color:var(--muted2);border:1px solid transparent;background:transparent;font-family:'Barlow Condensed',sans-serif;transition:all .2s;text-transform:uppercase;}
.tab.active{color:#fff;background:var(--red);border-color:var(--red);}
.tab:hover:not(.active){color:var(--white);background:rgba(255,255,255,.06);}
.grid-m{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:.75rem;}
.grid-s{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:.75rem;}
.grid-ch{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:.75rem;}
.grid-m3u{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:.75rem;}
.card{position:relative;border-radius:4px;overflow:hidden;background:var(--card);cursor:pointer;border:1px solid rgba(255,255,255,.04);transition:transform .25s,box-shadow .25s;animation:fadeUp .4s ease both;}
.card:hover{transform:scale(1.05) translateY(-4px);box-shadow:0 20px 50px rgba(0,0,0,.8),0 0 20px rgba(229,9,20,.12);z-index:5;}
.card-thumb{width:100%;aspect-ratio:2/3;position:relative;overflow:hidden;background:#111;display:flex;align-items:center;justify-content:center;font-size:3rem;}
.card-thumb.wide{aspect-ratio:16/9;font-size:2rem;}
.card-thumb img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .4s;}
.card:hover .card-thumb img{transform:scale(1.06);}
.card-ov{position:absolute;inset:0;background:linear-gradient(to top,rgba(8,8,8,.95),transparent 50%);opacity:0;transition:opacity .3s;display:flex;align-items:center;justify-content:center;}
.card:hover .card-ov{opacity:1;}
.play-ic{width:46px;height:46px;border-radius:50%;background:rgba(229,9,20,.9);display:flex;align-items:center;justify-content:center;font-size:1.1rem;color:#fff;transform:scale(.7);transition:transform .25s;}
.card:hover .play-ic{transform:scale(1);}
.card-bdg{position:absolute;top:6px;left:6px;font-family:'Share Tech Mono',monospace;font-size:.52rem;letter-spacing:1px;padding:2px 5px;border-radius:3px;background:var(--red);color:#fff;}
.card-body{padding:.6rem;}
.card-title{font-size:.88rem;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:.18rem;}
.card-meta2{display:flex;justify-content:space-between;font-size:.68rem;color:var(--muted2);font-family:'Share Tech Mono',monospace;}
.card-meta2 .s{color:var(--gold);}
.mini-bar{height:2px;background:rgba(255,255,255,.06);border-radius:1px;margin-top:.45rem;overflow:hidden;}
.mini-fill{height:100%;background:var(--red);border-radius:1px;}
.ch-card{background:var(--card);border:1px solid rgba(255,255,255,.05);border-radius:4px;padding:1rem;cursor:pointer;transition:all .2s;position:relative;overflow:hidden;}
.ch-card::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--red);transform:scaleX(0);transform-origin:left;transition:transform .3s;}
.ch-card:hover{transform:translateY(-3px);border-color:rgba(229,9,20,.2);}
.ch-card:hover::after{transform:scaleX(1);}
.ch-top{display:flex;justify-content:space-between;margin-bottom:.75rem;}
.ch-icon{width:44px;height:44px;border-radius:8px;background:#1a1a1a;display:flex;align-items:center;justify-content:center;font-size:1.3rem;border:1px solid rgba(255,255,255,.06);overflow:hidden;}
.ch-icon img{width:100%;height:100%;object-fit:contain;border-radius:6px;}
.live-pill{display:flex;align-items:center;gap:.28rem;background:rgba(229,9,20,.12);border:1px solid rgba(229,9,20,.3);border-radius:3px;padding:.15rem .42rem;font-size:.6rem;font-weight:700;color:var(--red);font-family:'Share Tech Mono',monospace;}
.ldot{width:5px;height:5px;border-radius:50%;background:var(--red);animation:ldotAnim 1.2s infinite;}
@keyframes ldotAnim{0%,100%{opacity:1}50%{opacity:.2}}
.ch-name{font-weight:700;font-size:.88rem;margin-bottom:.15rem;}
.ch-prog{font-size:.7rem;color:var(--muted2);}
.ch-prog-bar{margin-top:.75rem;height:2px;background:rgba(255,255,255,.06);border-radius:1px;overflow:hidden;}
.ch-prog-fill{height:100%;background:var(--red);border-radius:1px;}
.m3u-card{background:var(--card);border:1px solid rgba(255,255,255,.05);border-radius:4px;padding:1.1rem;cursor:pointer;transition:all .2s;animation:fadeUp .4s ease both;}
.m3u-card:hover{transform:translateY(-3px);border-color:rgba(229,9,20,.25);}
.m3u-card-top{display:flex;align-items:center;gap:.7rem;margin-bottom:.65rem;}
.m3u-flag{font-size:1.8rem;}
.m3u-card-title{font-weight:700;font-size:.92rem;margin-bottom:.08rem;}
.m3u-card-count{font-size:.68rem;color:var(--red);font-family:'Share Tech Mono',monospace;}
.m3u-card-desc{font-size:.72rem;color:var(--muted2);line-height:1.5;margin-bottom:.85rem;}
.m3u-btns{display:flex;gap:.4rem;}
.strip{background:rgba(229,9,20,.06);border-bottom:1px solid rgba(229,9,20,.12);padding:.5rem 2.5rem;display:flex;align-items:center;gap:.75rem;overflow:hidden;}
.strip-badge{font-family:'Share Tech Mono',monospace;font-size:.6rem;letter-spacing:2px;background:var(--red);color:#fff;padding:2px 6px;border-radius:2px;font-weight:700;flex-shrink:0;}
.strip-text{font-size:.78rem;color:rgba(255,255,255,.5);white-space:nowrap;animation:marquee 35s linear infinite;}
@keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.modal{display:none;position:fixed;inset:0;z-index:400;align-items:center;justify-content:center;background:rgba(0,0,0,.92);backdrop-filter:blur(10px);padding:1rem;}
.modal.open{display:flex;}
.modal-box{background:var(--bg2);border:1px solid rgba(255,255,255,.08);border-radius:10px;width:min(900px,97vw);max-height:92vh;overflow:hidden;animation:mIn .25s ease;display:flex;flex-direction:column;}
@keyframes mIn{from{opacity:0;transform:scale(.94)}to{opacity:1;transform:scale(1)}}
.modal-vid{width:100%;aspect-ratio:16/9;position:relative;flex-shrink:0;background:#000;}
.no-vid-ph{width:100%;height:100%;min-height:280px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.65rem;background:#0a0a0a;}
.no-vid-ph .ic{font-size:3rem;opacity:.15;}
.no-vid-ph p{color:#444;font-size:.82rem;font-family:'Share Tech Mono',monospace;}
.modal-close{position:absolute;top:10px;right:10px;z-index:10;background:rgba(0,0,0,.75);border:none;color:#fff;width:30px;height:30px;border-radius:50%;cursor:pointer;font-size:.9rem;transition:background .2s;display:flex;align-items:center;justify-content:center;}
.modal-close:hover{background:var(--red);}
.modal-body2{padding:1.25rem;overflow-y:auto;}
.modal-title2{font-family:'Bebas Neue',cursive;font-size:1.7rem;letter-spacing:1px;margin-bottom:.3rem;}
.modal-meta2{display:flex;gap:.75rem;font-size:.75rem;color:var(--muted2);flex-wrap:wrap;font-family:'Share Tech Mono',monospace;margin-bottom:.75rem;}
.modal-desc2{font-size:.88rem;color:rgba(255,255,255,.6);line-height:1.7;margin-bottom:1rem;}
.modal-acts{display:flex;gap:.55rem;flex-wrap:wrap;}
.source-switcher{display:flex;gap:.4rem;flex-wrap:wrap;}
.source-btn{padding:.3rem .7rem;border-radius:3px;font-size:.72rem;font-weight:700;letter-spacing:.5px;cursor:pointer;color:var(--muted2);border:1px solid rgba(255,255,255,.1);background:transparent;font-family:'Share Tech Mono',monospace;transition:all .2s;}
.source-btn.active{color:#fff;background:rgba(229,9,20,.3);border-color:var(--red);}
.source-btn:hover:not(.active){color:var(--white);background:rgba(255,255,255,.06);}
.subtitle-bar{display:flex;align-items:center;gap:.5rem;margin-bottom:.75rem;padding:.5rem .75rem;background:rgba(0,245,255,.05);border:1px solid rgba(0,245,255,.15);border-radius:4px;}
.subtitle-bar label{font-size:.7rem;color:var(--cyan);font-family:'Share Tech Mono',monospace;letter-spacing:1px;margin-right:.25rem;}
.subtitle-select{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);border-radius:3px;padding:.3rem .6rem;color:var(--white);font-family:'Barlow Condensed',sans-serif;font-size:.85rem;outline:none;cursor:pointer;}
.notice{background:rgba(229,9,20,.06);border:1px solid rgba(229,9,20,.15);border-radius:6px;padding:.65rem 1rem;font-size:.78rem;color:rgba(229,9,20,.9);margin-bottom:1.1rem;line-height:1.5;}
.spinner{width:30px;height:30px;border:3px solid rgba(255,255,255,.08);border-top-color:var(--red);border-radius:50%;animation:spin .8s linear infinite;margin:2.5rem auto;display:block;}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-wrap{display:flex;flex-direction:column;align-items:center;padding:2.5rem;gap:.85rem;color:var(--muted2);font-family:'Share Tech Mono',monospace;font-size:.78rem;}
.ndiv{height:1px;margin:0 2.5rem;background:linear-gradient(90deg,transparent,rgba(255,255,255,.06),transparent);}
footer{border-top:1px solid rgba(255,255,255,.05);padding:1.75rem 2.5rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;margin-top:1rem;}
.foot-brand{font-family:'Bebas Neue',cursive;font-size:1.3rem;letter-spacing:2px;color:var(--red);}
